Cell["Diffraction of a Cross", "Title",
 CellChangeTimes->{{3.5466777456317472`*^9, 3.546677749419819*^9}}],

Cell["\<\
Written by Nicolas Scozzaro,  5-20-12\
\>", "Text",
 CellChangeTimes->{{3.5466784245853777`*^9, 3.546678452838211*^9}}],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Remove", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]", "=", ".5"}], ";"}], " ", 
  RowBox[{"(*", 
