Cell["\<\
To make the aperture you can either define an electric field that is \
piecewise, then integrate over all of the aperture screen when calculating \
the electric field at the projection screen; or, you can define the electric \
field to be constant over the aperture screen and integrate over just the \
aperture. 
Below I make a piecewise electric field in the shape of a cross by using \
theta-functions, but the discontinuities leave white lines.\
\>", "Text",
 CellChangeTimes->{{3.546677538674644*^9, 3.546677562447744*^9}, {
  3.546677647504134*^9, 3.546677668061799*^9}, {3.546677775533492*^9, 
  3.5466777778834553`*^9}, {3.546677816874103*^9, 3.546678048774206*^9}, {
  3.546678080870782*^9, 3.546678132621009*^9}, {3.546678184577867*^9, 
  3.5466781973156157`*^9}, {3.546678272058869*^9, 3.546678303465199*^9}, {
  3.5466783655677567`*^9, 3.54667840172945*^9}, {3.546678480797986*^9, 
  3.546678860246643*^9}, {3.546680443753234*^9, 3.5466804834400997`*^9}, {
  3.546706098662128*^9, 3.5467061239933767`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ElectricFieldPrime", "[", 
    RowBox[{"xprime_", ",", " ", "yprime_"}], "]"}], " ", "=", " ", 
   RowBox[{"Eo", "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"xprime", " ", "+", " ", "10"}], "]"}], " ", "-", " ", 
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"xprime", " ", "-", " ", "10"}], "]"}]}], ")"}], "*", "\n", 
       "    ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"yprime", " ", "+", " ", "1"}], "]"}], " ", "-", " ", 
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"yprime", " ", "-", " ", "1"}], "]"}]}], ")"}]}], " ", "-", 
      " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"xprime", " ", "+", " ", "1.5"}], "]"}], " ", "-", " ", 
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"xprime", " ", "-", " ", "1.5"}], "]"}]}], ")"}], "*", "\n",
        "    ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"yprime", " ", "+", " ", "1"}], "]"}], " ", "-", " ", 
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"yprime", " ", "-", " ", "1"}], "]"}]}], ")"}]}], " ", "+", 
      " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"xprime", " ", "+", " ", "1.5"}], "]"}], " ", "-", " ", 
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"xprime", " ", "-", " ", "1.5"}], "]"}]}], ")"}], "*", "\n",
        "    ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"yprime", " ", "+", " ", "10"}], "]"}], " ", "-", " ", 
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"yprime", " ", "-", " ", "10"}], "]"}]}], ")"}]}]}], 
     ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"DensityPlot", "[", 
  RowBox[{
   RowBox[{"ElectricFieldPrime", "[", 
    RowBox[{"xprime", ",", "yprime"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"xprime", ",", 
     RowBox[{"-", "15"}], ",", "15"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"yprime", ",", 
     RowBox[{"-", "15"}], ",", "15"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input"],

