Cell[TextData[{
 "Instead, I will use an electric field of constant amplitude Eo over the \
aperture screen, but integrate over the just the cross in three pieces: first \
the horizontal slit, then the top rectangle, then the bottom rectangle. \n",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " spits out some unimportant warnings, so I \[OpenCurlyDoubleQuote]Quiet\
\[CloseCurlyDoubleQuote] them."
}], "Text",
 CellChangeTimes->{{3.546538320043112*^9, 3.546538345425144*^9}, 
   3.546538856334586*^9, {3.546539926467444*^9, 3.546539928056425*^9}, {
   3.546542808139172*^9, 3.546542847890421*^9}, {3.5465430313246107`*^9, 
   3.546543049346899*^9}, 3.546554662426351*^9, {3.546677074602565*^9, 
   3.54667724871052*^9}, 3.546677395829661*^9, {3.546678895145047*^9, 
   3.54667895515683*^9}, {3.5466790089481277`*^9, 3.5466791940113277`*^9}, 
   3.54667923268165*^9, {3.546679267871189*^9, 3.5466792707432528`*^9}, {
   3.546680237116467*^9, 3.546680275429016*^9}, {3.54668047418429*^9, 
   3.546680540022319*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ElectricField", "[", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"\[ImaginaryI]", " ", "\[Lambda]"}]], "z", " ", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        FractionBox[
         RowBox[{" ", 
          RowBox[{"Eo", " ", 
           RowBox[{"Exp", "[", 
            FractionBox[
             RowBox[{"2", " ", "\[Pi]", " ", "\[ImaginaryI]", " ", 
              SqrtBox[
               RowBox[{
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"x", "-", "xprime"}], ")"}], "2"], "+", 
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"y", "-", "yprime"}], ")"}], "2"], "+", 
                SuperscriptBox["z", "2"]}]]}], "\[Lambda]"], "]"}]}]}], 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x", "-", "xprime"}], ")"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"y", "-", "yprime"}], ")"}], "2"], "+", 
          SuperscriptBox["z", "2"]}]], ",", 
        RowBox[{"{", 
         RowBox[{"xprime", ",", 
          RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"yprime", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], "+", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"\[ImaginaryI]", " ", "\[Lambda]"}]], "z", " ", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        FractionBox[
         RowBox[{" ", 
          RowBox[{"Eo", " ", 
           RowBox[{"Exp", "[", 
            FractionBox[
             RowBox[{"2", " ", "\[Pi]", " ", "\[ImaginaryI]", " ", 
              SqrtBox[
               RowBox[{
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"x", "-", "xprime"}], ")"}], "2"], "+", 
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"y", "-", "yprime"}], ")"}], "2"], "+", 
                SuperscriptBox["z", "2"]}]]}], "\[Lambda]"], "]"}]}]}], 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x", "-", "xprime"}], ")"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"y", "-", "yprime"}], ")"}], "2"], "+", 
          SuperscriptBox["z", "2"]}]], ",", 
        RowBox[{"{", 
         RowBox[{"xprime", ",", 
          RowBox[{"-", "1.5"}], ",", "1.5"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"yprime", ",", 
          RowBox[{"-", "10"}], ",", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "+", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"\[ImaginaryI]", " ", "\[Lambda]"}]], "z", " ", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        FractionBox[
         RowBox[{" ", 
          RowBox[{"Eo", " ", 
           RowBox[{"Exp", "[", 
            FractionBox[
             RowBox[{"2", " ", "\[Pi]", " ", "\[ImaginaryI]", " ", 
              SqrtBox[
               RowBox[{
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"x", "-", "xprime"}], ")"}], "2"], "+", 
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"y", "-", "yprime"}], ")"}], "2"], "+", 
                SuperscriptBox["z", "2"]}]]}], "\[Lambda]"], "]"}]}]}], 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x", "-", "xprime"}], ")"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"y", "-", "yprime"}], ")"}], "2"], "+", 
          SuperscriptBox["z", "2"]}]], ",", 
        RowBox[{"{", 
         RowBox[{"xprime", ",", 
          RowBox[{"-", "1.5"}], ",", "1.5"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"yprime", ",", "1", ",", "10"}], "}"}]}], "]"}]}]}]}], ";"}],
   "//", "Quiet"}]], "Input",
 CellChangeTimes->{{3.546542892812842*^9, 3.5465429377739687`*^9}, {
   3.546543042312037*^9, 3.546543055281423*^9}, 3.5465431116390963`*^9, {
   3.54654314754175*^9, 3.546543167254621*^9}, 3.5465432486350527`*^9, 
   3.546543387106498*^9, {3.546544180133894*^9, 3.546544195257028*^9}, {
   3.546552598344303*^9, 3.5465526144632273`*^9}, {3.5465529167397957`*^9, 
   3.546552919789562*^9}, {3.5465530332424707`*^9, 3.5465530554451427`*^9}}],

Cell["\<\
Since the electric field is complex let\[CloseCurlyQuote]s instead look at \
the intensity, mod-squared of the electric field:\
\>", "Text",
 CellChangeTimes->{{3.546679291448354*^9, 3.546679404819736*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Intensity", "[", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"ElectricField", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "]"}], "^", "2"}]}], ";"}], "//",
   "Quiet"}]], "Input",
 CellChangeTimes->{{3.546544101386384*^9, 3.546544119504747*^9}, 
   3.546544153753634*^9, {3.546544220841012*^9, 3.54654422240627*^9}, 
   3.546555185224366*^9}],

Cell["\<\
Normally you would use Plot3D to plot a 3D function, but since the integral \
takes a long time to compute, attempting this quasi-continuously as Plot3D \
tries to do takes too long. 
Instead, I evaluate the intensity on the projection screen at discreet points \
.5microns apart (more resolution takes more time). I make an array using \
\[OpenCurlyDoubleQuote]Table,\[CloseCurlyDoubleQuote] over the region from \
-15 to +15 microns, which results in \
{{x1,y1,intensity1},{x2,y2,intensity2}...}, but ListPlot3D doesn\
\[CloseCurlyQuote]t want the extra brackets so I use \
\[OpenCurlyDoubleQuote]Flatten\[CloseCurlyDoubleQuote] to remove them. I then \
interpolate a 3rd-order polynomial between points. Note that this plot takes \
about 15 minutes on my computer.\
\>", "Text",
 CellChangeTimes->{{3.546679489019874*^9, 3.546679627015934*^9}, {
   3.546679657215692*^9, 3.546679929738632*^9}, {3.5466799614733953`*^9, 
   3.546680116647146*^9}, {3.546680301171318*^9, 3.5466803567309103`*^9}, {
   3.5466803997554703`*^9, 3.5466804054341507`*^9}, {3.5466805538706512`*^9, 
   3.5466806065655527`*^9}, 3.546693256299912*^9}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot3D", "[", 
  RowBox[{
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y", ",", 
         RowBox[{"Intensity", "[", 
          RowBox[{"x", ",", "y", ",", "1"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "15"}], ",", "15", ",", ".5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "15"}], ",", "15", ",", ".5"}], "}"}]}], "]"}], ",", 
     "1"}], "]"}], ",", 
   RowBox[{"Mesh", "\[Rule]", "None"}], ",", 
   RowBox[{"InterpolationOrder", "\[Rule]", "3"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<1\[Mu]\>\""}]}], "]"}]], "Input",
 CellChangeTimes->{{3.5465539063587418`*^9, 3.546553911499593*^9}, {
   3.546554082123851*^9, 3.546554083554049*^9}, {3.546554128040522*^9, 
   3.546554136335595*^9}, 3.546554330914297*^9, {3.5465543887332363`*^9, 
   3.546554397506472*^9}, {3.546554557107234*^9, 3.546554585468204*^9}, {
   3.54655493764717*^9, 3.546554943691856*^9}, {3.546555154143799*^9, 
   3.546555155246015*^9}, {3.546555411980772*^9, 3.5465554135803547`*^9}, 
   3.546555473708733*^9, {3.546555506480257*^9, 3.546555567102351*^9}}],

