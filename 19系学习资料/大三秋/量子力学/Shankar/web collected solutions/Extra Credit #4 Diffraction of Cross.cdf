   "Peak", " ", "amplitude", " ", "of", " ", "the", " ", "incident", " ", 
    "electric", " ", "field"}], "*)"}], " "}]}], "Input",
 CellChangeTimes->{{3.546535440721229*^9, 3.5465355749743958`*^9}, {
   3.546536196588485*^9, 3.546536200819149*^9}, {3.546536257680677*^9, 
