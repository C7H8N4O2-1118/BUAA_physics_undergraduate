   3.546676335243423*^9, 3.5466763407464333`*^9}, {3.546676753137979*^9, 
   3.546676770613947*^9}, {3.546677259156657*^9, 3.546677308163476*^9}, {
   3.546677375651104*^9, 3.5466774662601757`*^9}, {3.546677514765088*^9, 
