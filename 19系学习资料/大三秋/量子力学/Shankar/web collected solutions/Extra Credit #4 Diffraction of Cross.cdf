Cell["\<\
This plot is the just a different way of visualizing the last (100micron) \
plot, and takes an an hour and fifteen minutes on my computer because I boost \
the resolution to a quarter of a micron:\
\>", "Text",
 CellChangeTimes->{{3.5466801296560993`*^9, 3.5466801928290462`*^9}, {
  3.546693307099999*^9, 3.546693307976315*^9}, {3.54669896522087*^9, 
  3.5466989999600143`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListDensityPlot", "[", 
  RowBox[{
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y", ",", 
         RowBox[{"Intensity", "[", 
          RowBox[{"x", ",", "y", ",", "100"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
